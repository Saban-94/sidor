const API_URL = "https://script.google.com/macros/s/AKfycbw8T264S4_s2Epbx90lXRj3Ux6Mlj6jhLxkeX_oINqg8qzjrFdNmjlJWQ2MZygnCT5M/exec";

export const SabanAPI = {
  /**
   * פעולת התחברות: מוודאת שהלקוח קיים בגיליון ומחזירה את פרטיו
   * @param {string} phone - מספר טלפון (ללא מקפים)
   * @param {string} password - קוד אימות
   */
  login: async (phone, password) => {
    try {
      const response = await fetch(API_URL, {
        method: "POST",
        redirect: "follow", // קריטי ל-Google Scripts
        headers: {
          "Content-Type": "text/plain;charset=utf-8", // עוקף שגיאות CORS
        },
        body: JSON.stringify({ action: "login", phone, password })
      });
      return await response.json();
    } catch (error) {
      console.error("Login failed:", error);
      return { success: false, error: "שגיאת תקשורת מול השרת" };
    }
  },

  

  sendMessage: async (phone, message, imageBase64 = null) => {
    try {
      const response = await fetch(API_URL, {
        method: "POST",
        redirect: "follow",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify({ 
          action: "sendMessage", 
          phone, 
          message,
          image: imageBase64 // הוספת תמיכה בתמונות מהמצלמה
        })
      });
      return await response.json();
    } catch (error) {
      return { success: false, error: "שגיאת תקשורת" };
    }
  }
};
