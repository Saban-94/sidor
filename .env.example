# Firebase Configuration
# Get these values from your Firebase Console > Project Settings > Web App Configuration

# API Key for Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase Auth Domain
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase Realtime Database URL
# Format: https://your-project-default-rtdb.firebaseio.com/
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/

# Firebase Project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Storage Bucket
# Format: your-project.appspot.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Firebase App ID
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Optional: Enable debug logging
# DEBUG=saban-hub:*

# Optional: API Keys for integrations (future use)
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
# WHATSAPP_API_KEY=your_whatsapp_api_key
